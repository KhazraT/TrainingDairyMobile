<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/setItemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="2dp"
    android:paddingHorizontal="8dp"
    android:background="#10FF9800">

    <!-- Основной подход дропсета -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Номер подхода -->
        <TextView
            android:id="@+id/setNumberTextView"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/set_number_background"
            android:backgroundTint="#FF9800"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            tools:text="1" />

        <!-- Тип подхода (метка) -->
        <TextView
            android:id="@+id/setTypeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="дропсет"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="#FF9800"
            android:textStyle="bold"
            android:visibility="visible"
            android:layout_marginEnd="8dp" />

        <!-- Колонки с полями (вес и повторения) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Колонка: Вес -->
            <LinearLayout
                android:id="@+id/weightColumn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginHorizontal="2dp"
                android:visibility="visible">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/weightInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                    app:boxStrokeWidth="0dp"
                    app:boxBackgroundColor="#10FF9800">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/weightInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:inputType="numberDecimal"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textSize="14sp"
                        android:textColor="#FF9800"
                        tools:text="80" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="кг"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="#FF9800" />

            </LinearLayout>

            <!-- Колонка: Повторения -->
            <LinearLayout
                android:id="@+id/repsColumn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginHorizontal="2dp"
                android:visibility="visible">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/repsInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                    app:boxStrokeWidth="0dp"
                    app:boxBackgroundColor="#10FF9800">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/repsInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:inputType="number"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textSize="14sp"
                        android:textColor="#FF9800"
                        tools:text="10" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="повт"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="#FF9800" />

            </LinearLayout>

        </LinearLayout>

        <!-- Кнопка удаления -->
        <ImageButton
            android:id="@+id/deleteSetButton"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Удалить подход"
            android:src="@drawable/ic_delete"
            app:tint="#F44336" />

    </LinearLayout>

    <!-- Время отдыха + кнопка таймера (ТОЛЬКО для последнего подхода дропсета) -->
    <LinearLayout
        android:id="@+id/restTimeRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="4dp"
        android:paddingStart="34dp"
        android:paddingEnd="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Отдых:"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="#FF9800"
            android:layout_marginEnd="6dp"
            android:minWidth="40dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/restTimeInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="мм:сс"
            app:boxStrokeWidth="0dp"
            app:boxBackgroundColor="#10FF9800"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/restTimeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="time"
                android:focusable="false"
                android:clickable="true"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:textColor="#FF9800" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startRestTimerButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="▶"
            android:minWidth="36dp"
            android:minHeight="36dp"
            android:textSize="12sp"
            android:backgroundTint="#FF9800"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

</LinearLayout>