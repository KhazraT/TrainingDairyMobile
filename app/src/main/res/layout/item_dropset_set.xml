<?xml version="1.0" encoding="utf-8"?>
<!-- Дропсет запись — отображается под основным подходом -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="2dp"
    android:paddingHorizontal="8dp"
    android:background="#1AFF9800">

    <!-- Метка "Дропсет" -->
    <TextView
        android:id="@+id/dropsetLabel"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="6dp"
        android:gravity="center"
        android:text="↓"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="#FF9800"
        android:textStyle="bold"
        android:textSize="16sp" />

    <!-- Дропсет данные -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Вес дропсета -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/dropsetWeightInputLayout"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeWidth="0dp"
            app:boxBackgroundColor="?attr/colorSurface">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dropsetWeightInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="#FF9800"
                android:textSize="14sp"
                tools:text="60" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Повторения дропсета -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/dropsetRepsInputLayout"
            android:layout_width="45dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeWidth="0dp"
            app:boxBackgroundColor="?attr/colorSurface">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dropsetRepsInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="number"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="#FF9800"
                android:textSize="14sp"
                tools:text="5" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

</LinearLayout>
