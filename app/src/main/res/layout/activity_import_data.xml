<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:fitsSystemWindows="true"
    android:background="?android:attr/colorBackground">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Импорт данных"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginBottom="24dp" />

    <!-- Источник данных -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Источник данных"
        android:textSize="16sp"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_source"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/rb_local"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Локальный файл"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rb_cloud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Облачный сервис (Google Drive, etc.)" />
    </RadioGroup>

    <!-- Выбор файла -->
    <Button
        android:id="@+id/btn_select_file"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Выбрать файл"
        android:layout_marginBottom="16dp" />

    <!-- Информация -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Поддерживаемые форматы: JSON, CSV"
        android:textSize="14sp"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btn_import"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Импортировать"
        style="@style/Widget.MaterialComponents.Button" />

</LinearLayout>
