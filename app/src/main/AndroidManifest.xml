<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TrainingDairyMobile"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- Splash Activity как точка входа -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.TrainingDairyMobile.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false" />

        <!-- Register Activity -->
        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false" />

        <!-- Main Activity -->
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false" />

        <!-- Program Detail Activity -->
        <activity
            android:name=".ui.trainings.ProgramDetailActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Create Exercise Activity -->
        <activity
            android:name=".ui.exercises.CreateExerciseActivity"
            android:exported="false"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Exercise Detail Activity -->
        <activity
            android:name=".ui.exercises.ExerciseDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Workout Management Activity -->
        <activity
            android:name=".ui.trainings.WorkoutManagementActivity"
            android:exported="false"
            android:parentActivityName=".ui.trainings.ProgramDetailActivity" />

        <!-- Workout Content Activity -->
        <activity
            android:name=".ui.trainings.WorkoutContentActivity"
            android:exported="false"
            android:parentActivityName=".ui.trainings.ProgramDetailActivity" />

        <!-- Exercise Management Activity (упражнения в тренировке) -->
        <activity
            android:name=".ui.trainings.ExerciseManagementActivity"
            android:exported="false"
            android:parentActivityName=".ui.trainings.WorkoutManagementActivity" />

        <!-- Exercise Picker Activity (выбор упражнений с мультивыбором) -->
        <activity
            android:name=".ui.trainings.ExercisePickerActivity"
            android:exported="false"
            android:parentActivityName=".ui.trainings.ExerciseManagementActivity" />

        <!-- Session Activity (выполнение тренировки) -->
        <activity
            android:name=".ui.sessions.SessionActivity"
            android:exported="false"
            android:parentActivityName=".ui.trainings.ProgramDetailActivity" />

        <!-- Session History Activity (история тренировок) -->
        <activity
            android:name=".ui.trainings.SessionHistoryActivity"
            android:exported="false"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Session Detail Activity (детали сессии) -->
        <activity
            android:name=".ui.trainings.SessionDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.trainings.SessionHistoryActivity" />

        <!-- Body Measurements Activity (измерения тела) -->
        <activity
            android:name=".ui.statistics.BodyMeasurementsActivity"
            android:exported="false"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Exercise Stats Activity (статистика по упражнениям) -->
        <activity
            android:name=".ui.statistics.ExerciseStatsActivity"
            android:exported="false"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Edit Profile Activity -->
        <activity
            android:name=".ui.profile.EditProfileActivity"
            android:exported="false"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Settings Activity -->
        <activity
            android:name=".ui.profile.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Export Data Activity -->
        <activity
            android:name=".ui.profile.ExportDataActivity"
            android:exported="false"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Import Data Activity -->
        <activity
            android:name=".ui.profile.ImportDataActivity"
            android:exported="false"
            android:parentActivityName=".ui.main.MainActivity" />

    </application>
</manifest>
